# Copy this file to .env and modify the configuration

# ---- Application ----
APP_NAME=Ello Bot
APP_VERSION=1.0.0
DEBUG=false

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- Database ----
# SQLite:      sqlite:///./app.db
# MySQL:       mysql+pymysql://user:password@localhost/dbname
# PostgreSQL:  postgresql://user:password@localhost/dbname
DB_URL=sqlite:///./app.db

# ---- Redis ----
# Format: redis://[:password@]host:port/db
# Dev compose (docker-compose.dev.yaml) Redis password is 12345678
REDIS_URL=redis://:12345678@localhost:6379/0

# ---- JWT ----
# When DEBUG=false, JWT_SECRET_KEY must be at least 32 bytes.
JWT_SECRET_KEY=replace-with-a-32-byte-minimum-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_ISSUER=app
JWT_AUDIENCE=app

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760

# ---- OpenTelemetry ----
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ello-bot-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_ENVIRONMENT=dev
