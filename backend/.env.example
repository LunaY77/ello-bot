# Copy this file to .env and modify the configuration

# ---- Application ----
APP_NAME=Ello Bot
APP_VERSION=1.0.0
DEBUG=false

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- Database ----
# PostgreSQL (async): postgresql+asyncpg://user:password@localhost/dbname
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ello_bot

# ---- Redis ----
# Format: redis://[:password@]host:port/db
# Dev compose (docker-compose.dev.yaml) Redis password is 12345678
REDIS_URL=redis://:12345678@localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760

# ---- OpenTelemetry ----
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ello-bot-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_ENVIRONMENT=dev

# ---- Bootstrap Admin ----
BOOTSTRAP_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-bootstrap-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin

# ---- Auth / Sessions ----
AUTH_REGISTRATION_ENABLED=false
AUTH_ACCESS_TOKEN_TTL_SECONDS=1800
AUTH_REFRESH_TOKEN_TTL_DAYS=30
