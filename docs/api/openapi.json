  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health",
        "description": "Report database and Redis readiness for the running process.\n\nArgs:\n    runtime: Started application runtime.\n\nReturns:\n    Shared response envelope containing health booleans.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_HealthResponse_"
                }
              }
            }
          }
        }
      }
    },
    "/api/debug/runtime": {
      "get": {
        "tags": [
          "Debug"
        ],
        "summary": "Runtime Status",
        "description": "Return a lightweight snapshot of runtime state for debugging.\n\nArgs:\n    runtime: Started application runtime.\n\nReturns:\n    Shared response envelope containing runtime debug fields.",
        "operationId": "runtime_status_api_debug_runtime_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_RuntimeDebugResponse_"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/register": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Register",
        "description": "Register a user account and immediately issue session tokens.\n\nArgs:\n    payload: Registration payload validated by the schema layer.\n    request: Incoming HTTP request used for metadata extraction.\n    service: Session application service.\n\nReturns:\n    Shared response envelope containing the new auth tokens.",
        "operationId": "register_api_sessions_register_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_AuthTokenResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/login": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Login",
        "description": "Authenticate a user and issue a new pair of opaque tokens.\n\nArgs:\n    payload: Login payload validated by the schema layer.\n    request: Incoming HTTP request used for metadata extraction.\n    service: Session application service.\n\nReturns:\n    Shared response envelope containing the authenticated session state.",
        "operationId": "login_api_sessions_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_AuthTokenResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/refresh": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Refresh",
        "description": "Rotate an existing auth session using the supplied refresh token.\n\nArgs:\n    payload: Refresh payload validated by the schema layer.\n    request: Incoming HTTP request used for metadata extraction.\n    service: Session application service.\n\nReturns:\n    Shared response envelope containing the rotated auth tokens.",
        "operationId": "refresh_api_sessions_refresh_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_AuthTokenResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/logout": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Logout",
        "description": "Revoke the current access token and remove its cached snapshot.\n\nArgs:\n    auth: Authenticated request context.\n    service: Session application service.\n\nReturns:\n    Shared success envelope without payload data.",
        "operationId": "logout_api_sessions_logout_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_NoneType_"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/logout-all": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Logout All",
        "description": "Revoke all active sessions for the authenticated user.\n\nArgs:\n    auth: Authenticated request context.\n    service: Session application service.\n\nReturns:\n    Shared success envelope without payload data.",
        "operationId": "logout_all_api_sessions_logout_all_post",
        "responses": {
          "200": {
