# ---- Application ----
DEBUG=false

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- Database ----
DB_URL=postgresql+asyncpg://ello:replace-with-a-strong-password@postgres:5432/ello

# ---- Redis ----
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0

# ---- CORS ----
CORS_ORIGINS=["https://ello.example.com"]

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760

# ---- OpenTelemetry ----
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ello-bot-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_ENVIRONMENT=production

# ---- IAM Bootstrap ----
BOOTSTRAP_ENABLED=true
BOOTSTRAP_TENANT_SLUG=personal
BOOTSTRAP_TENANT_NAME=Personal
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-bootstrap-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin

# ---- AI SDK ----
AI_RECORD_CONTENT=false
AI_CONTENT_PREVIEW_CHARS=500
AI_DEFAULT_TIMEOUT_MS=60000
AI_TECHNICAL_RETRY_COUNT=1
AI_TECHNICAL_RETRY_BACKOFF_MS=250
AI_OPENAI__API_KEY=
AI_OPENAI__BASE_URL=https://api.openai.com/v1
AI_ANTHROPIC__API_KEY=
AI_ANTHROPIC__BASE_URL=https://api.anthropic.com/v1
AI_ANTHROPIC__API_VERSION=2023-06-01
AI_GEMINI__API_KEY=
AI_GEMINI__BASE_URL=https://generativelanguage.googleapis.com/v1beta
